# ============================================================
# WalletWise — Frontend Environment Variables
# ============================================================
# Copy this file to `.env` for local development.
#   cp .env.example .env
#
# ⚠️  For Render deployments, set these in the Render Dashboard
#     under your frontend service → Environment → Add Env Var.
#     REACT_APP_* variables are baked into the build at build-time.
# ============================================================

# The full URL of your deployed backend (no trailing slash).
# Local development:
REACT_APP_API_URL=http://localhost:5000

# Production (replace with your actual Render backend URL):
# REACT_APP_API_URL=https://walletwise-backend.onrender.com
